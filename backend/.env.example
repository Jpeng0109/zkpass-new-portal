# Server
NODE_ENV=development
PORT=5000

# MongoDB Atlas (SRV) — 从 Atlas → Connect → Drivers 复制
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/zkpassportal?retryWrites=true&w=majority

# 若 SRV 超时（VPN/公司网），用 Standard 连接串填下面这行（Connect → Drivers → Standard）
# MONGODB_URI_STANDARD=mongodb://USER:PASS@ac-xxx-shard-00-00.xxxxx.mongodb.net:27017,.../zkpassportal?ssl=true&replicaSet=...

# SRV 解析失败时可设公共 DNS
DNS_SERVERS=8.8.8.8,1.1.1.1

# 本地 Mongo（仅 Docker 自带 mongo 时用）
# MONGODB_URI=mongodb://127.0.0.1:27017/zkpassportal

# CORS — frontend dev server (Vite default 5173 or 8080)
CLIENT_ORIGIN=http://localhost:8080

# Platform economics
VERIFICATION_CREDIT_COST=18.5
TOPUP_PLATFORM_FEE_RATE=0.02
INVOICE_TAX_RATE=0.15

# Crypto treasury (display / validation)
OFFICIAL_USDC_ADDRESS=0x1fff6ab30f7e5d7b5269ddf525ade9f56744c527

# Optional API key for future JWT (Phase 2+)
API_KEY_SALT=change-me-in-production
